{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles and agency status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "dob": { "type": "string", "format": "date" },
        "country": { "type": "string" },
        "lookingFor": { "type": "string" },
        "photoURL": { "type": "string" },
        "additionalPhotos": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "string" },
        "educationLevel": { "type": "string" },
        "matchFlowId": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isCoinSeller": { "type": "boolean" },
        "isAgent": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "agencyId": { "type": "string" },
        "agencyStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "checkInStreak": { "type": "number", "description": "Consecutive days the user has checked in" },
        "lastCheckInDate": { "type": "string", "format": "date-time", "description": "The last time the user checked in" },
        "blocking": { "type": "array", "items": { "type": "string" } },
        "blockedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Agency": {
      "title": "Agency",
      "description": "Recruitment agency",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "agentUid": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Withdrawal request",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "diamonds": { "type": "number" },
        "amountKes": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles"
    },
    "/agencies/{agencyCode}": {
      "schema": "#/entities/Agency",
      "description": "Agencies indexed by code"
    },
    "/agencies/{agencyCode}/withdrawals/{withdrawalId}": {
      "schema": "#/entities/Withdrawal",
      "description": "Withdrawal requests for an agency"
    }
  }
}